<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:padding="24dp">

    <View
        android:layout_width="42dp"
        android:layout_height="5dp"
        android:layout_gravity="center"
        android:background="@color/divider"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Upravljanje vozilom"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="@color/text_dark"/>

    <LinearLayout
        android:id="@+id/layoutEditVehicle"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_bottom_sheet_item"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/outline_edit_24"
            app:tint="@color/primary_burgundy"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Uredi vozilo"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:textSize="16sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDeleteVehicle"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_bottom_sheet_item"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/outline_delete_24"
            app:tint="@color/danger_red"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Obriši vozilo"
            android:textColor="@color/danger_red"
            android:textStyle="bold"
            android:textSize="16sp"/>
    </LinearLayout>

</LinearLayout>