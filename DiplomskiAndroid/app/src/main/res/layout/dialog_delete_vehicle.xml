<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtDeleteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Obrisati vozilo?"
            android:textColor="@color/text_dark"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtDeleteMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Ova radnja se ne može poništiti."
            android:textColor="@color/text_gray"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Odustani"
                android:textAllCaps="false"
                android:textColor="@color/text_dark"
                app:backgroundTint="@color/surface_variant"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Obriši"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/danger_red"
                app:cornerRadius="14dp"/>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>