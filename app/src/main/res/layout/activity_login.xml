<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:paddingTop="48dp">

        <!-- Avatar ikona -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/primary_burgundy"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Naslov -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prijava"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            app:layout_constraintTop_toBottomOf="@id/cardAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Podnaslov -->
        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dobrodošli natrag"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"
            app:layout_constraintTop_toBottomOf="@id/txtTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Label Email -->
        <TextView
            android:id="@+id/lblEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Email adresa"
            android:textSize="13sp"
            android:textColor="@color/text_gray"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/txtSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email polje -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:startIconDrawable="@drawable/ic_email"
            app:startIconTint="@color/text_gray"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:boxStrokeColor="@color/primary_burgundy"
            app:boxStrokeColorStateList="@color/input_stroke_selector"
            app:boxBackgroundColor="@color/card_white"
            app:layout_constraintTop_toBottomOf="@id/lblEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="vas@email.com"
                android:inputType="textEmailAddress"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_gray" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label Lozinka -->
        <TextView
            android:id="@+id/lblPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Lozinka"
            android:textSize="13sp"
            android:textColor="@color/text_gray"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tilEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Lozinka polje -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="@color/text_gray"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_gray"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:boxStrokeColor="@color/primary_burgundy"
            app:boxStrokeColorStateList="@color/input_stroke_selector"
            app:boxBackgroundColor="@color/card_white"
            app:layout_constraintTop_toBottomOf="@id/lblPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_gray" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Zaboravljena lozinka -->
        <TextView
            android:id="@+id/txtForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zaboravili ste lozinku?"
            android:textSize="13sp"
            android:textColor="@color/primary_red"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tilPassword"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Button Prijava -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Prijava"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:layout_marginTop="20dp"
            app:backgroundTint="@color/primary_burgundy"
            app:rippleColor="@color/dark_red"
            app:cornerRadius="10dp"
            app:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/txtForgotPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Separator lijevo -->
        <View
            android:id="@+id/dividerLeft"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/text_gray"
            android:alpha="0.2"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/txtOr"
            app:layout_constraintBaseline_toBaselineOf="@id/txtOr" />

        <TextView
            android:id="@+id/txtOr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ili"
            android:textSize="12sp"
            android:textColor="@color/text_gray"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Separator desno -->
        <View
            android:id="@+id/dividerRight"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/text_gray"
            android:alpha="0.2"
            android:layout_marginTop="20dp"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toEndOf="@id/txtOr"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBaseline_toBaselineOf="@id/txtOr" />

        <!-- Registracija -->
        <TextView
            android:id="@+id/txtRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nemate račun? Registrirajte se"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/txtOr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>